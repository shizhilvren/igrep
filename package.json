{
  "name": "igrep_web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf pkg target",
    "clean-npm-module": "rm -rf node_modules",
    "preclean-all": "npm run clean-npm-module && npm run clean",
    "clean-all": "",
    "build-wasm": "wasm-pack build  --target bundler",
    "prebuildin": "npm run build-wasm",
    "buildin": "run-p type-check \"build-only {@}\" --",
    "prelink-ngram-index": "npm run buildin",
    "link-ngram-index": "ln -sf ../ngram-index dist/ngram-index",
    "prelink-lsp-index": "npm run link-ngram-index",
    "link-lsp-index": "ln -sf ../lsp-index dist/lsp-index",
    "build": "npm run link-lsp-index",
    "predev": "npm run link-lsp-index",
    "dev": "vite",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli web-src/"
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.7.0",
    "element-plus": "^2.13.6",
    "monaco-editor": "^0.52.2",
    "real-cancellable-promise": "^1.2.3",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.51.0",
    "eslint-plugin-vue": "~10.8.0",
    "igrep": "file:./pkg",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.51.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.3.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vite-plugin-wasm": "^3.6.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
